#include <Arduino.h>
#include <Servo.h>
#include <ServoEasing.hpp>

ServoEasing s1;
ServoEasing s2;

void setup() {
  s1.attach(6);   // your servo pins
  s2.attach(7);

  s1.setSpeed(60);  // degrees per second (tune)
  s2.setSpeed(60);

  s1.write(90);
  s2.write(90);
  delay(500);
}

void loop() {
  s1.easeTo(30);   // smooth move
  s2.easeTo(150);
  delay(800);

  s1.easeTo(120);
  s2.easeTo(60);
  delay(800);
}